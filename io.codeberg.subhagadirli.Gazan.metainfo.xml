<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.codeberg.subhagadirli.Gazan</id>
  <name>Gazan</name>
  <summary>Browse, upload, download and manage cloud files</summary>
  <description>
    <p>
      Gazan is a GTK4/Libadwaita frontend for rclone that lets you browse,
      upload, download, and manage files across cloud storage providers such
      as Google Drive, OneDrive, and Dropbox.
    </p>
  </description>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <developer id="io.codeberg.subhagadirli">
    <name>Subhan Gadirli</name>
  </developer>

  <launchable type="desktop-id">io.codeberg.subhagadirli.Gazan.desktop</launchable>

  <url type="homepage">https://codeberg.org/subhangadirli/gazan</url>
  <url type="bugtracker">https://codeberg.org/subhangadirli/gazan/issues</url>

  <recommends>
    <display_length compare="ge">768</display_length>
  </recommends>

  <requires>
    <internet>always</internet>
  </requires>

  <releases>
    <release version="0.2.0" date="2026-05-12">
      <description>
        <ul>
          <li>OAuth support for Google Drive, OneDrive, and Dropbox</li>
          <li>File transfer progress bar</li>
          <li>Desktop notifications</li>
          <li>About page with credits</li>
          <li>Delete option in remote management</li>
          <li>Fixed OAuth authentication issues with Dropbox and OneDrive</li>
          <li>Fixed provider list ordering and window resize behaviour</li>
        </ul>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1"/>
</component>
